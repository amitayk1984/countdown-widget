<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/layout_countdown"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/text_days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/widget_text_primary"
            android:textSize="52sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/days_left"
            android:textColor="@color/widget_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/text_event_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/widget_text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <ImageView
        android:id="@+id/image_celebration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/celebration_description"
        android:scaleType="centerInside"
        android:src="@drawable/party_celebration"
        android:visibility="gone" />

</FrameLayout>
